# Copy this file to .env and fill in real values.
# NEVER commit .env — it is in .gitignore.
IMAGE_TAG=latest

# SQL Server SA password (must meet SQL Server complexity requirements)
SA_PASSWORD=YourStrong@Password123

# JWT configuration (Secret must be at least 32 characters)
JWT_SECRET=your-super-secret-jwt-key-minimum-32-chars
JWT_ISSUER=https://BookVerseApi.com
JWT_AUDIENCE=https://BookVerseApi.com
JWT_EXPIRATION=15

# Admin user seeded on first startup
ADMIN_EMAIL=admin@bookverse.local
ADMIN_PASSWORD=Admin@Dev123!
ADMIN_FIRSTNAME=Admin
ADMIN_LASTNAME=User

# Stripe payment keys (use test keys for local dev)
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
FROM_EMAIL=noreply@bookverse.com
FROM_NAME=BookVerse
# Smtp 
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password

ASPNETCORE_ENVIRONMENT=Production

AUTOMAPPER_LICENSE_KEY=your_key_here

# Production CORS origin (only used when ASPNETCORE_ENVIRONMENT=Production)
CORS_ALLOWED_ORIGIN=https://bookverseapi.com